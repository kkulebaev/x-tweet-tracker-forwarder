{
  "name": "x-tweet-tracker-forwarder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drain Redis stream events and forward to Telegram group (Voyager).",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "screenshot": "tsx scripts/screenshot-tweet.ts"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.9.11",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.1",
    "playwright": "^1.54.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
