{
  "name": "x-tweet-tracker-forwarder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drain Redis stream events and forward to Telegram group (Voyager).",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dry-run:archetypes": "tsx src/scripts/dry-run-archetypes.ts"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.9.11",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
